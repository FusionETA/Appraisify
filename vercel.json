{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/api/app" },
    { "source": "/views/index.html", "destination": "/api/app" },
    { "source": "/install", "destination": "/api/install" }
  ]
}
